<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_referral_policy_tree" model="ir.ui.view">
        <field name="name">referral.policy.tree</field>
        <field name="model">referral.policy</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="point_per_referral"/>
                <field name="max_point_monthly"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_referral_policy_form" model="ir.ui.view">
        <field name="name">referral.policy.form</field>
        <field name="model">referral.policy</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="active"/>
                        <field name="point_per_referral"/>
                        <field name="max_point_monthly"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_referral_policy_client" model="ir.actions.client">
        <field name="name">Kelola Kebijakan Referral</field>
        <field name="tag">referral_policy_client_action</field>
    </record>

    <menuitem id="menu_referral_policy" 
              name="Kebijakan" 
              parent="referral_registration.menu_referral_root" 
              action="action_referral_policy_client" 
              sequence="5"/>
</odoo>
