<templates xml:space="preserve">
<t t-name="referral_dashboard.DashboardTemplate">
<div class="nomar-dashboard-wrap">
<!--  Header  -->
<div class="nomar-dash-header">
<div class="nomar-dash-title-group">
<span class="nomar-dash-icon">☕</span>
<div>
<h1 class="nomar-dash-title">Dashboard Analitik Referral</h1>
<p class="nomar-dash-sub">PT Nomar Kopi</p>
</div>
</div>
<div class="nomar-period-bar">
<button t-on-click="() => this.setPeriod('week')" t-att-class="state.period === 'week' ? 'nomar-period-btn active' : 'nomar-period-btn'">Minggu Ini</button>
<button t-on-click="() => this.setPeriod('month')" t-att-class="state.period === 'month' ? 'nomar-period-btn active' : 'nomar-period-btn'">Bulan Ini</button>
<button t-on-click="() => this.setPeriod('year')" t-att-class="state.period === 'year' ? 'nomar-period-btn active' : 'nomar-period-btn'">Tahun Ini</button>
<button t-on-click="() => this.setPeriod('all')" t-att-class="state.period === 'all' ? 'nomar-period-btn active' : 'nomar-period-btn'">Semua</button>
</div>
</div>
<!--  Loading  -->
<t t-if="state.isLoading">
<div class="nomar-loading">
<div class="nomar-spinner"/>
<span>Memuat data dashboard...</span>
</div>
</t>
<!--  Error  -->
<t t-elif="state.errorMessage">
<div class="nomar-alert error">
<span>⚠</span>
<span t-esc="state.errorMessage"/>
</div>
</t>
<!--  Content  -->
<t t-else="">
<!--  KPI Cards — full width, 3 columns  -->
<div class="nomar-kpi-grid">
<div class="nomar-kpi-card nomar-kpi-blue">
<div class="nomar-kpi-icon">👥</div>
<div class="nomar-kpi-info">
<div class="nomar-kpi-label">Total Jumlah Referral</div>
<div class="nomar-kpi-value">
<t t-esc="state.kpiData.totalReferrals"/>
</div>
<div class="nomar-kpi-desc">Transaksi referral berhasil</div>
</div>
</div>
<div class="nomar-kpi-card nomar-kpi-green">
<div class="nomar-kpi-icon">💰</div>
<div class="nomar-kpi-info">
<div class="nomar-kpi-label">Total Pendapatan Referral</div>
<div class="nomar-kpi-value">
<t t-esc="state.kpiData.totalRevenue"/>
</div>
<div class="nomar-kpi-desc">Nilai transaksi dari referral</div>
</div>
</div>
<div class="nomar-kpi-card nomar-kpi-gold">
<div class="nomar-kpi-icon">⭐</div>
<div class="nomar-kpi-info">
<div class="nomar-kpi-label">Total Poin Dikeluarkan</div>
<div class="nomar-kpi-value">
<t t-esc="state.kpiData.totalPoints"/>
</div>
<div class="nomar-kpi-desc">Poin reward diberikan</div>
</div>
</div>
</div>
<!--  Leaderboard  -->
<div class="nomar-leaderboard-card">
<div class="nomar-leaderboard-header">
<span class="nomar-lb-bar"/>
<h2>Top Referrer</h2>
</div>
<t t-if="state.topReferrers.length === 0">
<div class="nomar-empty">
<span>📋</span>
<p>Belum ada transaksi referral pada periode ini.</p>
</div>
</t>
<t t-else="">
<table class="nomar-lb-table">
<thead>
<tr>
<th class="nomar-th-rank">Peringkat</th>
<th>Nama Member</th>
<th class="nomar-th-r">Jumlah Referral Sukses</th>
<th class="nomar-th-r">Total Poin Diperoleh</th>
</tr>
</thead>
<tbody>
<t t-foreach="state.topReferrers" t-as="referral" t-key="referral.id">
<tr>
<td class="nomar-td-rank">
<span t-att-class="referral_index === 0 ? 'nomar-badge gold' : referral_index === 1 ? 'nomar-badge silver' : referral_index === 2 ? 'nomar-badge bronze' : 'nomar-badge plain'">
<t t-esc="referral_index + 1"/>
</span>
</td>
<td class="nomar-td-name">
<t t-esc="referral.name"/>
</td>
<td class="nomar-td-r nomar-td-bold">
<t t-esc="referral.referrals"/>
</td>
<td class="nomar-td-r nomar-td-gold">
<t t-esc="referral.points"/>
</td>
</tr>
</t>
</tbody>
</table>
</t>
</div>
</t>
</div>
</t>
</templates>