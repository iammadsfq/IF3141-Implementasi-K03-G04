<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

  <t t-name="referral_dashboard.PolicyTemplate">
    <div class="nomar-policy-wrap">

      <!-- Policy Card -->
      <div class="nomar-policy-card">

        <!-- Card Header -->
        <div class="nomar-policy-card-header">
          <div class="nomar-header-icon">&#9881;</div>
          <div>
            <h2>Kelola Kebijakan Referral</h2>
            <p>Sesuaikan parameter program referral untuk menjaga keseimbangan antara akuisisi pelanggan dan profitabilitas.</p>
          </div>
        </div>

        <!-- Card Body -->
        <div class="nomar-policy-body">

          <!-- Success Alert -->
          <t t-if="state.showSuccess">
            <div class="nomar-alert success">
              <span>&#10003;</span>
              <span>Perubahan Tersimpan — Kebijakan referral berhasil diperbarui dan telah diaktifkan untuk semua pengguna.</span>
            </div>
          </t>

          <!-- Error Alert -->
          <t t-if="state.showError">
            <div class="nomar-alert error">
              <span>&#9888;</span>
              <span t-esc="state.errorMessage"/>
            </div>
          </t>

          <!-- Loading -->
          <t t-if="state.isLoading">
            <div class="nomar-loading">
              <div class="nomar-spinner"/>
              <span>Memuat kebijakan aktif...</span>
            </div>
          </t>

          <!-- Form -->
          <t t-else="">
            <div class="nomar-form-row">
              <div class="nomar-form-group">
                <label for="nomar_point_per_ref">Poin per Referral</label>
                <input id="nomar_point_per_ref"
                       type="number" min="1"
                       t-att-value="state.pointPerReferral"
                       t-on-input="(e) => this.state.pointPerReferral = e.target.value"
                       placeholder="Contoh: 50"/>
                <div class="nomar-field-desc">
                  Jumlah poin Nomar yang diberikan kepada referrer saat teman mereka
                  menyelesaikan transaksi pertama.
                </div>
              </div>
              <div class="nomar-form-group">
                <label for="nomar_max_monthly">Max Point Monthly</label>
                <input id="nomar_max_monthly"
                       type="number" min="1"
                       t-att-value="state.maxPointMonthly"
                       t-on-input="(e) => this.state.maxPointMonthly = e.target.value"
                       placeholder="Contoh: 1000"/>
                <div class="nomar-field-desc">
                  Batas maksimal poin yang dapat dikumpulkan oleh satu akun
                  dari program referral dalam periode satu bulan.
                </div>
              </div>
            </div>

            <!-- Actions -->
            <div class="nomar-policy-actions">
              <button class="nomar-btn-secondary"
                      t-att-disabled="state.isSaving"
                      t-on-click="cancel">Batal</button>
              <button class="nomar-btn-primary"
                      t-att-disabled="state.isSaving"
                      t-on-click="savePolicy">
                <t t-if="state.isSaving">Menyimpan...</t>
                <t t-else="">Simpan</t>
              </button>
            </div>
          </t>

          <!-- Guide -->
          <div class="nomar-guide">
            <h4>PANDUAN</h4>
            <ul>
              <li><strong>Perubahan Kebijakan</strong> — Perubahan poin per referral akan berlaku untuk
                <em>referral baru</em> yang terjadi setelah tombol simpan ditekan. Referral yang sedang
                dalam proses akan menggunakan rate lama.</li>
              <li><strong>Catatan Administratif</strong> — Batas poin bulanan (Max Point Monthly)
                di-reset pada tanggal 1 setiap bulannya pada pukul 00:00 WIB.</li>
            </ul>
          </div>

        </div>
      </div>
    </div>
  </t>

</templates>
